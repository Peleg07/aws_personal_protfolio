.claude/
s3_bucket_prod/
git_commands.txt

# Local .terraform directories
**/.terraform/*

# Terraform state files - never commit these!
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Sensitive variable files - never commit these!
*.tfvars
*.tfvars.json
terraform.tfvars
**/*.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform lock file (optional - some teams commit this)
# .terraform.lock.hcl
